# Backend Environment Variables
# 复制本文件为 `backend/.env` 或仓库根目录 `.env` 并填写；Django 会加载两处（见 config/settings.py）。
DEBUG=True
DATABASE_URL=mysql://root:password@localhost:3306/travel_app
DB_NAME=travel_app
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DJANGO_SECRET_KEY=change-this-to-a-random-secret-key
OSRM_URL=http://router.project-osrm.org

# 智能行程：OpenAI 兼容 LLM（勿将 KEY 写入日志或提交仓库）
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=70

# 百度地图（POI 检索，与智能行程落库共用）
BAIDU_MAP_AK=
# 智能行程确认落库时，两次百度 place 请求之间的间隔（秒）；默认 0.35，可按配额调大
BAIDU_SMART_COMMIT_INTERVAL_SEC=0.35
