# Backend Environment Variables
# 复制本文件为 `backend/.env` 或仓库根目录 `.env` 并填写；Django 会加载两处（见 config/settings.py）。
DEBUG=True
DATABASE_URL=mysql://root:password@localhost:3306/travel_app
DB_NAME=travel_app
DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DJANGO_SECRET_KEY=change-this-to-a-random-secret-key
OSRM_URL=http://router.project-osrm.org

# 智能行程：OpenAI 兼容 LLM（勿将 KEY 写入日志或提交仓库）
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=70

# 百度地图（POI 检索，与智能行程落库共用）
BAIDU_MAP_AK=
# 智能行程确认落库时，两次百度 place 请求之间的间隔（秒）；默认 0.35，可按配额调大
BAIDU_SMART_COMMIT_INTERVAL_SEC=0.35

# POI 外部搜索（百度 / Nominatim）结果缓存 TTL（秒）
POI_GEOSEARCH_CACHE_TTL=86400
# 境外搜索：公共 Nominatim（须遵守 https://operations.osmfoundation.org/policies/nominatim/ ）
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# 必填风格建议：应用名/版本 (联系邮箱) — 库默认 UA、纯浏览器直连 API 常被 403 Access denied
NOMINATIM_USER_AGENT=YourAppName/1.0 (you@example.com)
# 可选：你的网站或前端地址，政策接受 Referer 或 User-Agent 二选一标识应用
# NOMINATIM_REFERER=https://your-frontend.example/
# 两次出站 Nominatim 请求最小间隔（秒），公共实例约 1 请求/秒
NOMINATIM_MIN_INTERVAL_SEC=1.1
# 本机代理（仅 Nominatim 使用，不影响百度）。直连 OSM 超时则填云梯等提供的端口，例如：
# NOMINATIM_PROXY=http://127.0.0.1:7897
# Docker 内后端需指向宿主机，如 http://host.docker.internal:7897（Mac/Win）
